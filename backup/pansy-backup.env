# PANSY metadata backup configuration for revontuli.uit.no.
#
# Install this file as:
#   ~/.config/pansy-backup/pansy-backup.env

JUMP_HOST=j@4.235.86.214
PANSY_SSH_HOST=radar@localhost
PANSY_SSH_PORT=3131
LOCAL_TUNNEL_PORT=2222

REMOTE_METADATA_ROOT=/media/analysis/metadata
LOCAL_METADATA_ROOT=/mnt/data/juha/pansy/metadata
LOCAL_MIRROR_METADATA_ROOT=/urdr/data/juha/pansy/metadata
METADATA_CHANNELS="clock cut detections mesomode phase simple_meteor_fit tx"

# Channels reported for the Revontuli-to-URDR mirror. The mirror copies the
# complete metadata root, including Revontuli-generated orbit metadata.
LOCAL_MIRROR_METADATA_CHANNELS="clock cut detections mesomode orbit phase simple_meteor_fit tx"

# Keep this low because the satellite link is precious.
RSYNC_BWLIMIT_KB=50
RSYNC_SLEEP_SECONDS=60
LOCAL_MIRROR_SLEEP_SECONDS=300
LOCAL_MIRROR_BWLIMIT_KB=0

STATE_DIR=/mnt/data/juha/pansy/backup_state
WEB_BUILD_DIR=/mnt/data/juha/pansy/web

WEB_HOST=j@4.235.86.214
WEB_ROOT=/var/www/html/pansy
WEB_DEPLOY_SLEEP_SECONDS=300
DETECTION_HISTORY_SLEEP_SECONDS=900
DETECTION_HISTORY_WORKERS=8
DETECTION_HISTORY_RESCAN_DAYS=3
PHASE_HISTORY_SLEEP_SECONDS=900
PHASE_HISTORY_WORKERS=8
PHASE_HISTORY_RESCAN_DAYS=3
