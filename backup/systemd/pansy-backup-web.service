[Unit]
Description=PANSY backup web status publisher
After=pansy-backup-rsync.service
Wants=pansy-backup-rsync.service

[Service]
Type=simple
Environment=PANSY_RECEIVER_REPO=__PANSY_RECEIVER_REPO__
ExecStart=__PANSY_RECEIVER_REPO__/backup/scripts/pansy_backup_status_loop.sh
Restart=always
RestartSec=60

[Install]
WantedBy=default.target
