# PANSY receiver user-service configuration for syowa-meteor.
#
# Install this file as:
#   ~/.config/pansy-receiver/pansy-receiver.env

PANSY_RECEIVER_REPO=/home/radar/src/git/pansy_receiver
PANSY_UHD_RX_SERVICE=pansy-uhd-rx.service
PANSY_UHD_RX_BINARY=/home/radar/src/git/pansy_receiver/pansy_uhd_rx
PANSY_UHD_RX_OUTDIR=/media/archive
PANSY_UHD_RX_ARGS=
PANSY_UHD_RX_LD_LIBRARY_PATH=/home/radar/.syowa/lib

PANSY_WATCH_CHANNELS=ch000,ch001,ch002,ch003,ch004,ch005,ch006,ch007
PANSY_STALE_SECONDS=300
PANSY_CHECK_SECONDS=10
PANSY_RESTART_COOLDOWN_SECONDS=120
PANSY_STOP_TIMEOUT_SECONDS=45

PANSY_PHASE_ROOT=/media/analysis/metadata/phase
PANSY_PHASE_MAX_JUMP_DEG=30
PANSY_PHASE_LOOKBACK_DAYS=30
PANSY_PHASE_MIN_BASELINE=10
PANSY_PHASE_CHECK_TIMEOUT_SECONDS=1200
PANSY_PHASE_MAX_RESTARTS=3
