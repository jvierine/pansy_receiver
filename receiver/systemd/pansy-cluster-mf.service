[Unit]
Description=PANSY matched-filter clustering
After=pansy-find-mode-starts.service
Wants=pansy-find-mode-starts.service

[Service]
Type=simple
Environment=PANSY_RECEIVER_REPO=__PANSY_RECEIVER_REPO__
Environment=PANSY_RECEIVER_CONFIG=%h/.config/pansy-receiver/pansy-receiver.env
WorkingDirectory=__PANSY_RECEIVER_REPO__
ExecStart=__PANSY_RECEIVER_REPO__/receiver/scripts/pansy_processing_service.sh python3 cluster_mf.py
Restart=always
RestartSec=30
StandardOutput=append:__PANSY_RECEIVER_REPO__/logs/pansy_cluster_mf.log
StandardError=append:__PANSY_RECEIVER_REPO__/logs/pansy_cluster_mf.log

[Install]
WantedBy=default.target
