[Unit]
Description=PANSY meteor cutout producer
After=pansy-quick-search-meteor.service
Wants=pansy-quick-search-meteor.service

[Service]
Type=simple
Environment=PANSY_RECEIVER_REPO=__PANSY_RECEIVER_REPO__
Environment=PANSY_RECEIVER_CONFIG=%h/.config/pansy-receiver/pansy-receiver.env
WorkingDirectory=__PANSY_RECEIVER_REPO__
ExecStart=__PANSY_RECEIVER_REPO__/receiver/scripts/pansy_processing_service.sh python3 cut_meteors.py
Restart=always
RestartSec=30
StandardOutput=append:__PANSY_RECEIVER_REPO__/logs/pansy_cut_meteors.log
StandardError=append:__PANSY_RECEIVER_REPO__/logs/pansy_cut_meteors.log

[Install]
WantedBy=default.target
