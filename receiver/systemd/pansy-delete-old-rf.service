[Unit]
Description=PANSY old raw-voltage file cleanup

[Service]
Type=simple
Environment=PANSY_RECEIVER_REPO=__PANSY_RECEIVER_REPO__
Environment=PANSY_RECEIVER_CONFIG=%h/.config/pansy-receiver/pansy-receiver.env
ExecStart=__PANSY_RECEIVER_REPO__/receiver/scripts/pansy_delete_old_rf.sh
Restart=always
RestartSec=20
StandardOutput=append:__PANSY_RECEIVER_REPO__/logs/pansy_delete_old_rf.log
StandardError=append:__PANSY_RECEIVER_REPO__/logs/pansy_delete_old_rf.log

[Install]
WantedBy=default.target
