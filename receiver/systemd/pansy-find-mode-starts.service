[Unit]
Description=PANSY transmit mode-start metadata finder
After=pansy-uhd-rx.service
Wants=pansy-uhd-rx.service

[Service]
Type=simple
Environment=PANSY_RECEIVER_REPO=__PANSY_RECEIVER_REPO__
Environment=PANSY_RECEIVER_CONFIG=%h/.config/pansy-receiver/pansy-receiver.env
WorkingDirectory=__PANSY_RECEIVER_REPO__
ExecStart=__PANSY_RECEIVER_REPO__/receiver/scripts/pansy_processing_service.sh python3 find_mode_starts.py
Restart=always
RestartSec=20
StandardOutput=append:__PANSY_RECEIVER_REPO__/logs/pansy_find_mode_starts.log
StandardError=append:__PANSY_RECEIVER_REPO__/logs/pansy_find_mode_starts.log

[Install]
WantedBy=default.target
