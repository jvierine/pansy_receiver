[Unit]
Description=PANSY mesomode boundary metadata generator
After=pansy-find-mode-starts.service
Wants=pansy-find-mode-starts.service

[Service]
Type=simple
Environment=PANSY_RECEIVER_REPO=__PANSY_RECEIVER_REPO__
Environment=PANSY_RECEIVER_CONFIG=%h/.config/pansy-receiver/pansy-receiver.env
WorkingDirectory=__PANSY_RECEIVER_REPO__
ExecStart=__PANSY_RECEIVER_REPO__/receiver/scripts/pansy_processing_service.sh __PANSY_RECEIVER_REPO__/receiver/scripts/pansy_wait_for_paths.sh /media/analysis/metadata/tx/dmd_properties.h5 -- python3 mesomode_boundary.py
Restart=always
RestartSec=30
StandardOutput=append:__PANSY_RECEIVER_REPO__/logs/pansy_mesomode_boundary.log
StandardError=append:__PANSY_RECEIVER_REPO__/logs/pansy_mesomode_boundary.log

[Install]
WantedBy=default.target
