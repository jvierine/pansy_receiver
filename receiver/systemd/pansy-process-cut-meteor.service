[Unit]
Description=PANSY meteor cutout processor
After=pansy-cut-meteors.service
Wants=pansy-cut-meteors.service

[Service]
Type=simple
Environment=PANSY_RECEIVER_REPO=__PANSY_RECEIVER_REPO__
Environment=PANSY_RECEIVER_CONFIG=%h/.config/pansy-receiver/pansy-receiver.env
WorkingDirectory=__PANSY_RECEIVER_REPO__
ExecStart=__PANSY_RECEIVER_REPO__/receiver/scripts/pansy_processing_service.sh __PANSY_RECEIVER_REPO__/receiver/scripts/pansy_wait_for_paths.sh /media/analysis/metadata/cut/dmd_properties.h5 -- mpirun -np 2 python3 process_cut_meteor.py
Restart=always
RestartSec=30
StandardOutput=append:__PANSY_RECEIVER_REPO__/logs/pansy_process_cut_meteor.log
StandardError=append:__PANSY_RECEIVER_REPO__/logs/pansy_process_cut_meteor.log

[Install]
WantedBy=default.target
