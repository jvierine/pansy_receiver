[Unit]
Description=PANSY UHD receiver data and phase watchdog
After=pansy-uhd-rx.service
Wants=pansy-uhd-rx.service

[Service]
Type=simple
Environment=PANSY_RECEIVER_REPO=__PANSY_RECEIVER_REPO__
Environment=PANSY_RECEIVER_CONFIG=%h/.config/pansy-receiver/pansy-receiver.env
ExecStart=__PANSY_RECEIVER_REPO__/receiver/scripts/pansy_uhd_watchdog.py
Restart=always
RestartSec=20
StandardOutput=append:__PANSY_RECEIVER_REPO__/logs/pansy_uhd_watchdog.log
StandardError=append:__PANSY_RECEIVER_REPO__/logs/pansy_uhd_watchdog.log

[Install]
WantedBy=default.target
